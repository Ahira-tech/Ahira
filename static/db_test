<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ahira — Database Test</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Segoe UI', system-ui, sans-serif;
    background: #0f0a1e;
    color: #e2d9f3;
    min-height: 100vh;
    padding: 32px 20px;
  }
  .container { max-width: 720px; margin: 0 auto; }
  h1 {
    font-size: 26px; font-weight: 700;
    background: linear-gradient(135deg, #a78bfa, #f472b6);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 6px;
  }
  .subtitle { font-size: 13px; color: #7c6a9e; margin-bottom: 28px; }

  .section { margin-bottom: 24px; }
  .section-title {
    font-size: 11px; font-weight: 700; letter-spacing: 1.5px;
    text-transform: uppercase; color: #7c6a9e;
    margin-bottom: 12px; padding-left: 4px;
  }

  .card {
    background: #1a1030;
    border: 1px solid #2e1f4a;
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 12px;
  }

  .card-header {
    display: flex; align-items: center; gap: 12px;
    padding: 16px 18px;
    border-bottom: 1px solid #2e1f4a;
  }
  .card-icon { font-size: 22px; }
  .card-name { font-size: 15px; font-weight: 600; color: #e2d9f3; }
  .card-desc { font-size: 12px; color: #7c6a9e; margin-top: 2px; }
  .status-badge {
    margin-left: auto; padding: 4px 12px; border-radius: 20px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.5px;
  }
  .badge-waiting { background: rgba(251,191,36,0.12); color: #fbbf24; border: 1px solid rgba(251,191,36,0.3); }
  .badge-ok      { background: rgba(34,197,94,0.12);  color: #4ade80; border: 1px solid rgba(34,197,94,0.3); }
  .badge-fail    { background: rgba(248,113,113,0.12); color: #f87171; border: 1px solid rgba(248,113,113,0.3); }

  .card-body { padding: 14px 18px; }
  .result-row {
    display: flex; justify-content: space-between;
    font-size: 13px; padding: 5px 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .result-row:last-child { border-bottom: none; }
  .result-key { color: #9980c8; }
  .result-val { color: #e2d9f3; font-weight: 500; font-family: monospace; font-size: 12px; }
  .result-val.ok   { color: #4ade80; }
  .result-val.fail { color: #f87171; }
  .result-val.warn { color: #fbbf24; }

  .log-box {
    background: #0d0a1a; border-radius: 10px; padding: 14px;
    font-family: monospace; font-size: 12px; line-height: 1.8;
    color: #9980c8; max-height: 260px; overflow-y: auto;
    white-space: pre-wrap; margin-top: 12px;
  }
  .log-ok   { color: #4ade80; }
  .log-fail { color: #f87171; }
  .log-info { color: #93c5fd; }
  .log-warn { color: #fbbf24; }

  .btn-row { display: flex; gap: 10px; margin-bottom: 20px; flex-wrap: wrap; }
  button {
    padding: 11px 22px; border: none; border-radius: 10px;
    font-size: 13px; font-weight: 600; cursor: pointer;
    transition: opacity 0.15s, transform 0.12s;
    font-family: inherit;
  }
  button:active { transform: scale(0.96); }
  .btn-primary {
    background: linear-gradient(135deg, #7c3aed, #db2777);
    color: white;
  }
  .btn-secondary {
    background: rgba(255,255,255,0.06); color: #c4b5fd;
    border: 1px solid rgba(196,181,253,0.2);
  }
  button:disabled { opacity: 0.4; cursor: not-allowed; }

  .summary-bar {
    display: flex; gap: 10px; margin-bottom: 24px; flex-wrap: wrap;
  }
  .summary-box {
    flex: 1; min-width: 120px; text-align: center;
    background: #1a1030; border: 1px solid #2e1f4a;
    border-radius: 14px; padding: 16px 10px;
  }
  .summary-num { font-size: 32px; font-weight: 700; font-family: 'Segoe UI'; }
  .summary-lbl { font-size: 11px; color: #7c6a9e; margin-top: 4px; }

  #overallResult {
    text-align: center; padding: 14px; border-radius: 14px;
    font-size: 15px; font-weight: 600; margin-top: 20px;
    display: none;
  }
  .overall-ok   { background: rgba(34,197,94,0.1);  color: #4ade80; border: 1px solid rgba(34,197,94,0.25); }
  .overall-warn { background: rgba(251,191,36,0.1); color: #fbbf24; border: 1px solid rgba(251,191,36,0.25); }
  .overall-fail { background: rgba(248,113,113,0.1);color: #f87171; border: 1px solid rgba(248,113,113,0.25); }
</style>
</head>
<body>
<div class="container">
  <h1>🔬 Ahira Database Test</h1>
  <p class="subtitle">Checks PostgreSQL and MongoDB connectivity, then tests core app functions</p>

  <div class="btn-row">
    <button class="btn-primary" onclick="runAllTests()" id="runBtn">▶ Run All Tests</button>
    <button class="btn-secondary" onclick="clearLogs()">↺ Clear</button>
    <button class="btn-secondary" onclick="window.location.href='/'">← Back to App</button>
  </div>

  <div class="summary-bar">
    <div class="summary-box">
      <div class="summary-num" id="passCount" style="color:#4ade80;">-</div>
      <div class="summary-lbl">Passed</div>
    </div>
    <div class="summary-box">
      <div class="summary-num" id="failCount" style="color:#f87171;">-</div>
      <div class="summary-lbl">Failed</div>
    </div>
    <div class="summary-box">
      <div class="summary-num" id="warnCount" style="color:#fbbf24;">-</div>
      <div class="summary-lbl">Warnings</div>
    </div>
  </div>

  <!-- PostgreSQL Card -->
  <div class="section">
    <div class="section-title">PostgreSQL (Users, Sessions, Reminders)</div>
    <div class="card" id="pgCard">
      <div class="card-header">
        <div class="card-icon">🐘</div>
        <div>
          <div class="card-name">PostgreSQL</div>
          <div class="card-desc">dpg-d77ok1ua2pns73au3t3g-a / ahira_db</div>
        </div>
        <span class="status-badge badge-waiting" id="pgBadge">WAITING</span>
      </div>
      <div class="card-body" id="pgBody">
        <div style="color:#7c6a9e;font-size:13px;">Run tests to see results...</div>
      </div>
    </div>
  </div>

  <!-- MongoDB Card -->
  <div class="section">
    <div class="section-title">MongoDB (Chat Logs, Analytics)</div>
    <div class="card" id="mgCard">
      <div class="card-header">
        <div class="card-icon">🍃</div>
        <div>
          <div class="card-name">MongoDB Atlas</div>
          <div class="card-desc">cluster0.yl8d8av.mongodb.net / ahira_db</div>
        </div>
        <span class="status-badge badge-waiting" id="mgBadge">WAITING</span>
      </div>
      <div class="card-body" id="mgBody">
        <div style="color:#7c6a9e;font-size:13px;">Run tests to see results...</div>
      </div>
    </div>
  </div>

  <!-- App Endpoint Tests -->
  <div class="section">
    <div class="section-title">App Endpoint Tests</div>
    <div class="card">
      <div class="card-header">
        <div class="card-icon">🌐</div>
        <div>
          <div class="card-name">API Endpoints</div>
          <div class="card-desc">Health, auth, reminders</div>
        </div>
        <span class="status-badge badge-waiting" id="apiBadge">WAITING</span>
      </div>
      <div class="card-body" id="apiBody">
        <div style="color:#7c6a9e;font-size:13px;">Run tests to see results...</div>
      </div>
    </div>
  </div>

  <div id="overallResult"></div>

  <div class="section" style="margin-top:20px;">
    <div class="section-title">Test Log</div>
    <div class="log-box" id="logBox">Click "Run All Tests" to begin...\n</div>
  </div>
</div>

<script>
let passed = 0, failed = 0, warned = 0;

function log(type, msg) {
  const box = document.getElementById('logBox');
  const ts = new Date().toLocaleTimeString();
  box.innerHTML += `<span class="log-${type}">[${ts}] ${msg}</span>\n`;
  box.scrollTop = box.scrollHeight;
}

function clearLogs() {
  document.getElementById('logBox').innerHTML = 'Log cleared.\n';
  passed = failed = warned = 0;
  updateCounts();
  ['pgBadge','mgBadge','apiBadge'].forEach(id => {
    const el = document.getElementById(id);
    el.textContent = 'WAITING';
    el.className = 'status-badge badge-waiting';
  });
  ['pgBody','mgBody','apiBody'].forEach(id => {
    document.getElementById(id).innerHTML = '<div style="color:#7c6a9e;font-size:13px;">Run tests to see results...</div>';
  });
  document.getElementById('overallResult').style.display = 'none';
}

function updateCounts() {
  document.getElementById('passCount').textContent = passed;
  document.getElementById('failCount').textContent = failed;
  document.getElementById('warnCount').textContent = warned;
}

function rowHTML(key, val, status='') {
  return `<div class="result-row">
    <span class="result-key">${key}</span>
    <span class="result-val ${status}">${val}</span>
  </div>`;
}

async function testDbStatus() {
  log('info', '═══ Testing /db-status endpoint ═══');
  try {
    const res = await fetch('/db-status');
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const data = await res.json();

    // PostgreSQL
    const pg = data.postgresql;
    const pgOk = pg.backend === 'postgresql';
    let pgHTML = '';
    pgHTML += rowHTML('Backend', pg.backend, pgOk ? 'ok' : 'warn');
    pgHTML += rowHTML('psycopg2 available', pg.psycopg2_available ? 'Yes' : 'No', pg.psycopg2_available ? 'ok' : 'fail');
    pgHTML += rowHTML('Postgres URL set', pg.postgres_url_set ? 'Yes' : 'No', pg.postgres_url_set ? 'ok' : 'fail');

    document.getElementById('pgBody').innerHTML = pgHTML;
    const pgBadge = document.getElementById('pgBadge');
    if (pgOk) {
      pgBadge.textContent = 'CONNECTED'; pgBadge.className = 'status-badge badge-ok';
      log('ok', `✅ PostgreSQL: backend=${pg.backend}`); passed++;
    } else {
      pgBadge.textContent = 'FALLBACK'; pgBadge.className = 'status-badge badge-warning';
      log('warn', `⚠️ PostgreSQL: using ${pg.backend} fallback`); warned++;
    }

    // MongoDB
    const mg = data.mongodb;
    let mgHTML = '';
    mgHTML += rowHTML('Connected', mg.connected ? 'Yes' : 'No', mg.connected ? 'ok' : 'fail');
    if (mg.connected) {
      mgHTML += rowHTML('Collections', mg.collections.length > 0 ? mg.collections.join(', ') : '(empty)', 'ok');
    } else {
      mgHTML += rowHTML('Error', mg.error || 'Unknown', 'fail');
    }

    document.getElementById('mgBody').innerHTML = mgHTML;
    const mgBadge = document.getElementById('mgBadge');
    if (mg.connected) {
      mgBadge.textContent = 'CONNECTED'; mgBadge.className = 'status-badge badge-ok';
      log('ok', `✅ MongoDB: connected, collections=[${mg.collections.join(', ')}]`); passed++;
    } else {
      mgBadge.textContent = 'FAILED'; mgBadge.className = 'status-badge badge-fail';
      log('fail', `❌ MongoDB: ${mg.error}`); failed++;
    }

    return { pg: pgOk, mg: mg.connected };

  } catch (e) {
    log('fail', `❌ /db-status failed: ${e.message}`);
    document.getElementById('pgBadge').textContent = 'ERROR';
    document.getElementById('pgBadge').className = 'status-badge badge-fail';
    document.getElementById('mgBadge').textContent = 'ERROR';
    document.getElementById('mgBadge').className = 'status-badge badge-fail';
    failed++;
    return { pg: false, mg: false };
  }
}

async function testEndpoints() {
  log('info', '\n═══ Testing App Endpoints ═══');
  const results = [];

  // 1. Health
  try {
    const res = await fetch('/health');
    const data = await res.json();
    const ok = data.status === 'ok';
    results.push({ name: 'GET /health', val: data.status, ok });
    log(ok ? 'ok' : 'fail', `${ok ? '✅' : '❌'} GET /health → ${JSON.stringify(data)}`);
    ok ? passed++ : failed++;
  } catch(e) {
    results.push({ name: 'GET /health', val: e.message, ok: false });
    log('fail', `❌ GET /health → ${e.message}`); failed++;
  }

  // 2. /me (guest)
  try {
    const res = await fetch('/me');
    const data = await res.json();
    const ok = data.status === 'guest' || data.status === 'ok';
    results.push({ name: 'GET /me', val: data.status, ok });
    log(ok ? 'ok' : 'warn', `${ok ? '✅' : '⚠️'} GET /me → status=${data.status}`);
    ok ? passed++ : warned++;
  } catch(e) {
    results.push({ name: 'GET /me', val: e.message, ok: false });
    log('fail', `❌ GET /me → ${e.message}`); failed++;
  }

  // 3. GET /reminders
  try {
    const res = await fetch('/reminders');
    const data = await res.json();
    const ok = Array.isArray(data.tasks);
    results.push({ name: 'GET /reminders', val: `${data.tasks?.length ?? '?'} tasks`, ok });
    log(ok ? 'ok' : 'fail', `${ok ? '✅' : '❌'} GET /reminders → ${data.tasks?.length} tasks`);
    ok ? passed++ : failed++;
  } catch(e) {
    results.push({ name: 'GET /reminders', val: e.message, ok: false });
    log('fail', `❌ GET /reminders → ${e.message}`); failed++;
  }

  // 4. POST /add_reminder (write test)
  const testTask = `DB Test ${Date.now()}`;
  let testId = null;
  try {
    const res = await fetch('/add_reminder', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ task: testTask, date: null, time: null, priority: 'normal' })
    });
    const data = await res.json();
    const ok = data.status === 'success';
    results.push({ name: 'POST /add_reminder', val: data.status, ok });
    log(ok ? 'ok' : 'fail', `${ok ? '✅' : '❌'} POST /add_reminder → ${data.status}`);
    ok ? passed++ : failed++;

    if (ok) {
      // Find the ID we just created
      const r2 = await fetch('/reminders');
      const d2 = await r2.json();
      const found = d2.tasks.find(t => t.task === testTask);
      testId = found?.id;
      log('info', `   Created reminder id=${testId}`);
    }
  } catch(e) {
    results.push({ name: 'POST /add_reminder', val: e.message, ok: false });
    log('fail', `❌ POST /add_reminder → ${e.message}`); failed++;
  }

  // 5. Toggle reminder
  if (testId) {
    try {
      const res = await fetch(`/reminder/${testId}/toggle`, { method: 'POST' });
      const data = await res.json();
      const ok = data.status === 'updated';
      results.push({ name: 'POST /reminder/toggle', val: data.status, ok });
      log(ok ? 'ok' : 'fail', `${ok ? '✅' : '❌'} Toggle reminder ${testId} → ${data.status}`);
      ok ? passed++ : failed++;
    } catch(e) {
      results.push({ name: 'POST /reminder/toggle', val: e.message, ok: false });
      log('fail', `❌ Toggle → ${e.message}`); failed++;
    }
  }

  // 6. Delete reminder (cleanup)
  if (testId) {
    try {
      const res = await fetch(`/reminder/${testId}`, { method: 'DELETE' });
      const data = await res.json();
      const ok = data.status === 'deleted';
      results.push({ name: 'DELETE /reminder', val: data.status, ok });
      log(ok ? 'ok' : 'fail', `${ok ? '✅' : '❌'} DELETE reminder ${testId} → ${data.status}`);
      ok ? passed++ : failed++;
    } catch(e) {
      results.push({ name: 'DELETE /reminder', val: e.message, ok: false });
      log('fail', `❌ DELETE → ${e.message}`); failed++;
    }
  }

  // Render results
  let html = results.map(r => rowHTML(r.name, r.val, r.ok ? 'ok' : 'fail')).join('');
  document.getElementById('apiBody').innerHTML = html;

  const allOk = results.every(r => r.ok);
  const apiBadge = document.getElementById('apiBadge');
  if (allOk) {
    apiBadge.textContent = 'ALL PASS'; apiBadge.className = 'status-badge badge-ok';
  } else {
    apiBadge.textContent = 'SOME FAIL'; apiBadge.className = 'status-badge badge-fail';
  }
}

async function runAllTests() {
  passed = failed = warned = 0;
  document.getElementById('logBox').innerHTML = '';
  document.getElementById('overallResult').style.display = 'none';
  const btn = document.getElementById('runBtn');
  btn.disabled = true; btn.textContent = '⏳ Running...';

  log('info', `🔬 Ahira Database Test — ${new Date().toLocaleString()}`);
  log('info', `   Checking connections and endpoints...\n`);

  await testDbStatus();
  await testEndpoints();

  updateCounts();

  // Overall verdict
  const overall = document.getElementById('overallResult');
  overall.style.display = 'block';
  if (failed === 0 && warned === 0) {
    overall.textContent = `✅ All ${passed} tests passed! Both databases are connected and working.`;
    overall.className = 'overall-ok';
  } else if (failed === 0) {
    overall.textContent = `⚠️ ${passed} passed, ${warned} warnings. Check MongoDB URL/password if needed.`;
    overall.className = 'overall-warn';
  } else {
    overall.textContent = `❌ ${failed} failed, ${passed} passed, ${warned} warnings. Check logs above.`;
    overall.className = 'overall-fail';
  }

  log('info', `\n─── FINAL: ${passed} passed · ${failed} failed · ${warned} warnings ───`);
  btn.disabled = false; btn.textContent = '▶ Run All Tests';
}
</script>
</body>
</html>
